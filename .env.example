# AutoArticle Configuration
# Provider: anthropic (default) or zai/zhipu

# === Anthropic (default) ===
ANTHROPIC_API_KEY=sk-ant-
AUTOARTICLE_PROVIDER=anthropic
AUTOARTICLE_WRITER_MODEL=claude-sonnet-4-20250514
AUTOARTICLE_JUDGE_MODEL=claude-sonnet-4-20250514
AUTOARTICLE_API_BASE_URL=https://api.anthropic.com

# === ZAI / GLM (ZhipuAI) ===
# Uncomment and fill in to use ZAI instead of Anthropic
# AUTOARTICLE_PROVIDER=zai
# GLM_API_KEY=your-zai-api-key
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4
# AUTOARTICLE_WRITER_MODEL=glm-4-plus  # or glm-4-0520, glm-4-0116, etc.
# AUTOARTICLE_JUDGE_MODEL=glm-4-plus
